nkit_reviews.csv\")\n","zepto_df = pd.read_csv(\"/content/drive/MyDrive/Capstone/DATASET/zepto_reviews.csv\")\n","\n","# Add platform identifier\n","blinkit_df['platform'] = 'Blinkit'\n","zepto_df['platform'] = 'Zepto'\n","\n","# Combine datasets\n","df = pd.concat([blinkit_df, zepto_df], ignore_index=True)\n","\n","# -------------------------\n","# 2. Exploratory Data Analysis\n","# -------------------------\n","plt.figure(figsize=(12, 6))\n","\n","# Rating distribution\n","plt.subplot(1, 2, 1)\n","sns.countplot(x='score', hue='platform', data=df, palette=['#FF6B6B', '#4ECDC4'])\n","plt.title('Rating Distribution by Platform')\n","plt.xlabel('Rating Score')\n","plt.ylabel('Count')\n","\n","# Platform comparison\n","plt.subplot(1, 2, 2)\n","platform_counts = df['platform'].value_counts()\n","plt.pie(platform_counts, labels=platform_counts.index, autopct='%1.1f%%',\n","        colors=['#FF6B6B', '#4ECDC4'], startangle=90)\n","plt.title('Platform Distribution')\n","plt.tight_layout()\n","plt.savefig('eda_ratings_platform.png', dpi=300)\n","plt.show()\n","\n","# -------------------------\n","# 3. Create Sentiment Labels\n","# -------------------------\n","# 0 = Negative, 1 = Neutral, 2 = Positive\n","df['sentiment'] = df['score'].apply(lambda x: 0 if x <= 2 else (1 if x == 3 else 2))\n","\n","# Sentiment distribution\n","plt.figure(figsize=(10, 6))\n","sns.countplot(x='sentiment', hue='platform', data=df, palette=['#FF6B6B', '#4ECDC4'])\n","plt.title('Sentiment Distribution by Platform')\n","plt.xlabel('Sentiment')\n","plt.ylabel('Count')\n","plt.xticks([0, 1, 2], ['Negative', 'Neutral', 'Positive'])\n","plt.legend(title='Platform')\n","plt.savefig('sentiment_distribution.png', dpi=300)\n","plt.show()"],"metadata":{"id":"SnuO2iJumbIl","colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"status":"ok","timestamp":1758649514490,"user_tz":-330,"elapsed":18797,"user":{"displayName":"Mansi Srivastava","userId":"04702383556101533094"}},"outputId":"227f2f4b-80ad-4558-81c4-3e8b32743e4a"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 2 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["NEW"],"metadata":{"id":"x0JfMq1Hqnen"}},{"cell_type":"code","source":["# -------------------------\n","# 0. Setup & Enhanced Imports\n","# -------------------------\n","import pandas as pd\n","import numpy as np\n","import matplotlib.pyplot as plt\n","import seaborn as sns\n","import emoji\n","from wordcloud import WordCloud\n","from collections import Counter\n","from sklearn.feature_extraction.text import CountVectorizer\n","import warnings\n","warnings.filterwarnings('ignore')\n","\n","# Set style for professional business presentation\n","plt.style.use('seaborn-v0_8-whitegrid')\n","sns.set_palette(\"husl\")\n","\n","# -------------------------\n","# 1. Load Data & Initial Setup\n","# -------------------------\n","blinkit_df = pd.read_csv(\"/content/drive/MyDrive/Capstone/DATASET/blinkit_reviews.csv\")\n","zepto_df = pd.read_csv(\"/content/drive/MyDrive/Capstone/DATASET/zepto_reviews.csv\")\n","\n","blinkit_df['platform'] = 'Blinkit'\n","zepto_df['platform'] = 'Zepto'\n","df = pd.concat([blinkit_df, zepto_df], ignore_index=True)\n","\n","print(\"Dataset shape:\", df.shape)\n","print(\"Columns:\", df.columns)\n","\n","# Identify review column\n","review_col = \"content\"  # Adjust if different\n","\n","# Data cleaning\n","df = df.drop_duplicates()\n","df = df.dropna(subset=[review_col, 'score'])\n","\n","# Sentiment mapping for business analysis\n","df['sentiment'] = df['score'].apply(lambda x: 0 if x <= 2 else (1 if x == 3 else 2))\n","df['sentiment_label'] = df['sentiment'].map({0: 'Negative', 1: 'Neutral', 2: 'Positive'})\n","\n","print(f\"Total Reviews: {len(df)}\")\n","print(f\"Blinkit Reviews: {len(df[df['platform']=='Blinkit'])}\")\n","print(f\"Zepto Reviews: {len(df[df['platform']=='Zepto'])}\")\n","\n","# -------------------------\n","# 2. EXECUTIVE SUMMARY DASHBOARD\n","# -------------------------\n","print(\"\\n\" + \"=\"*60)\n","print(\"EXECUTIVE SUMMARY: BLINKIT vs ZEPTO BUSINESS INTELLIGENCE\")\n","print(\"=\"*60)\n","\n","# Key Metrics Calculation\n","blinkit_data = df[df['platform'] == 'Blinkit']\n","zepto_data = df[df['platform'] == 'Zepto']\n","\n","metrics = {\n","    'Platform': ['Blinkit', 'Zepto'],\n","    'Total Reviews': [len(blinkit_data), len(zepto_data)],\n","    'Avg Rating': [blinkit_data['score'].mean(), zepto_data['score'].mean()],\n","    'Positive Sentiment %': [\n","        len(blinkit_data[blinkit_data['sentiment'] == 2])/len(blinkit_data)*100,\n","        len(zepto_data[zepto_data['sentiment'] == 2])/len(zepto_data)*100\n","    ],\n","    'Negative Sentiment %': [\n","        len(blinkit_data[blinkit_data['sentiment'] == 0])/len(blinkit_data)*100,\n","        len(zepto_data[zepto_data['sentiment'] == 0])/len(zepto_data)*100\n","    ]\n","}\n","\n","metrics_df = pd.DataFrame(metrics)\n","print(\"\\nKEY PERFORMANCE INDICATORS:\")\n","print(metrics_df.round(2))\n","\n","# -------------------------\n","# 3. COMPREHENSIVE BUSINESS ANALYSIS VISUALIZATION\n","# -------------------------\n","\n","# Create subplot grid for comprehensive analysis\n","fig = plt.figure(figsize=(20, 16))\n","\n","# 3.1 Market Presence & Volume Analysis\n","plt.subplot(3, 3, 1)\n","platform_share = df['platform'].value_counts()\n","plt.pie(platform_share.values, labels=platform_share.index, autopct='%1.1f%%',\n","        colors=['#FF6B6B', '#4ECDC4'], startangle=90)\n","plt.title('Market Review Volume Share\\n(Market Presence Indicator)', fontweight='bold')\n","\n","# 3.2 Customer Satisfaction Score (CSAT)\n","plt.subplot(3, 3, 2)\n","avg_ratings = df.groupby('platform')['score'].mean().reset_index()\n","sns.barplot(x='platform', y='score', data=avg_ratings, palette=['#FF6B6B', '#4ECDC4'])\n","plt.title('Average Customer Rating\\n(Customer Satisfaction Score)', fontweight='bold')\n","plt.ylabel('Average Rating (1-5)')\n","\n","# 3.3 Sentiment Distribution Comparison\n","plt.subplot(3, 3, 3)\n","sentiment_pivot = pd.crosstab(df['platform'], df['sentiment_label'], normalize='index') * 100\n","sentiment_pivot.plot(kind='bar', ax=plt.gca(), color=['#FF6B6B', '#FFD166', '#06D6A0'])\n","plt.title('Sentiment Distribution %\\n(Customer Experience Quality)', fontweight='bold')\n","plt.ylabel('Percentage (%)')\n","plt.xticks(rotation=0)\n","\n","# 3.4 Rating Distribution Deep Dive\n","plt.subplot(3, 3, 4)\n","rating_dist = pd.crosstab(df['platform'], df['score'])\n","rating_dist.plot(kind='bar', ax=plt.gca(), width=0.8)\n","plt.title('Detailed Rating Distribution\\n(Service Quality Analysis)', fontweight='bold')\n","plt.xlabel('Platform')\n","plt.ylabel('Number of Reviews')\n","plt.legend(title='Rating', bbox_to_anchor=(1.05, 1), loc='upper left')\n","\n","# 3.5 Review Engagement Analysis (Word Count)\n","plt.subplot(3, 3, 5)\n","df['word_count'] = df[review_col].astype(str).apply(lambda x: len(x.split()))\n","sns.boxplot(x='platform', y='word_count', data=df, palette=['#FF6B6B', '#4ECDC4'])\n","plt.title('Review Length Distribution\\n(Customer Engagement Level)', fontweight='bold')\n","plt.ylabel('Word Count')\n","\n","# 3.6 Rating Trend Over Time (if date available)\n","plt.subplot(3, 3, 6)\n","if 'date' in df.columns:\n","    df['date'] = pd.to_datetime(df['date'], errors='coerce')\n","    df['month'] = df['date'].dt.to_period('M')\n","    monthly_avg = df.groupby(['month', 'platform'])['score'].mean().unstack()\n","    monthly_avg.plot(ax=plt.gca(), marker='o', linewidth=2.5)\n","    plt.title('Monthly Average Rating Trend\\n(Performance Tracking)', fontweight='bold')\n","    plt.ylabel('Average Rating')\n","    plt.xticks(rotation=45)\n","else:\n","    plt.text(0.5, 0.5, 'Date data not available\\nfor trend analysis',\n","             ha='center', va='center', transform=plt.gca().transAxes)\n","    plt.title('Rating Trend Analysis\\n(Data Not Available)', fontweight='bold')\n","\n","# 3.7 Net Promoter Score (NPS) Calculation\n","plt.subplot(3, 3, 7)\n","def calculate_nps(scores):\n","    promoters = len(scores[scores >= 4])\n","    detractors = len(scores[scores <= 2])\n","    total = len(scores)\n","    return (promoters - detractors) / total * 100 if total > 0 else 0\n","\n","nps_scores = {\n","    'Blinkit': calculate_nps(blinkit_data['score']),\n","    'Zepto': calculate_nps(zepto_data['score'])\n","}\n","\n","plt.bar(nps_scores.keys(), nps_scores.values(), color=['#FF6B6B', '#4ECDC4'])\n","plt.title('Net Promoter Score (NPS)\\n(Customer Loyalty Metric)', fontweight='bold')\n","plt.ylabel('NPS Score')\n","plt.axhline(y=0, color='black', linestyle='-', alpha=0.3)\n","plt.axhline(y=50, color='green', linestyle='--', alpha=0.5, label='Excellent')\n","plt.axhline(y=0, color='orange', linestyle='--', alpha=0.5, label='Good')\n","plt.legend()\n","\n","# 3.8 Response Rate Analysis (if thumbsUpCount available)\n","plt.subplot(3, 3, 8)\n","if 'thumbsUpCount' in df.columns:\n","    engagement = df.groupby('platform')['thumbsUpCount'].mean()\n","    plt.bar(engagement.index, engagement.values, color=['#FF6B6B', '#4ECDC4'])\n","    plt.title('Average Helpful Votes\\n(Review Engagement Metric)', fontweight='bold')\n","    plt.ylabel('Average Helpful Votes')\n","else:\n","    # Alternative: Review complexity as engagement proxy\n","    df['review_complexity'] = df[review_col].apply(lambda x: len(set(str(x).split())))\n","    complexity = df.groupby('platform')['review_complexity'].mean()\n","    plt.bar(complexity.index, complexity.values, color=['#FF6B6B', '#4ECDC4'])\n","    plt.title('Average Vocabulary Diversity\\n(Review Quality Proxy)', fontweight='bold')\n","    plt.ylabel('Unique Words per Review')\n","\n","# 3.9 Market Gap Analysis\n","plt.subplot(3, 3, 9)\n","# Identify common pain points and strengths\n","negative_reviews = df[df['sentiment'] == 0]\n","common_issues = negative_reviews.groupby('platform').size()\n","plt.pie(common_issues.values, labels=common_issues.index, autopct='%1.1f%%',\n","        colors=['#FF6B6B', '#4ECDC4'])\n","plt.title('Distribution of Negative Reviews\\n(Problem Area Analysis)', fontweight='bold')\n","\n","plt.tight_layout()\n","plt.show()\n","\n","# -------------------------\n","# 4. TEXT ANALYSIS FOR BUSINESS INSIGHTS\n","# -------------------------\n","\n","# 4.1 Keyword Analysis for Strategic Insights\n","print(\"\\n\" + \"=\"*50)\n","print(\"STRATEGIC KEYWORD ANALYSIS\")\n","print(\"=\"*50)\n","\n","def extract_business_insights(text_series, platform_name, sentiment_type):\n","    \"\"\"Extract business-relevant keywords and phrases\"\"\"\n","    text = \" \".join(text_series.dropna().astype(str))\n","\n","    # Business-related keywords to track\n","    business_categories = {\n","        'Delivery': ['delivery', 'delivered', 'shipping', 'arrived', 'time', 'late', 'early', 'fast', 'slow'],\n","        'Quality': ['quality', 'fresh', 'freshness', 'expired', 'rotten', 'good quality', 'bad quality'],\n","        'Service': ['service', 'customer service', 'support', 'help', 'responsive', 'rude'],\n","        'Pricing': ['price', 'expensive', 'cheap', 'affordable', 'cost', 'value', 'money'],\n","        'App Experience': ['app', 'interface', 'easy to use', 'complicated', 'bug', 'crash'],\n","        'Product Range': ['variety', 'selection', 'available', 'out of stock', 'missing items']\n","    }\n","\n","    print(f\"\\n{platform_name} - {sentiment_type} Reviews Analysis:\")\n","    text_lower = text.lower()\n","\n","    for category, keywords in business_categories.items():\n","        matches = sum(1 for keyword in keywords if keyword in text_lower)\n","        if matches > 0:\n","            print(f\"  {category}: {matches} mentions\")\n","\n","# Apply to both platforms and sentiments\n","for platform in ['Blinkit', 'Zepto']:\n","    platform_data = df[df['platform'] == platform]\n","    for sentiment, label in [(2, 'Positive'), (0, 'Negative')]:\n","        sentiment_data = platform_data[platform_data['sentiment'] == sentiment]\n","        if len(sentiment_data) > 0:\n","            extract_business_insights(sentiment_data[review_col], platform, label)\n","\n","# 4.2 Competitive Advantage Analysis through Word Clouds\n","print(\"\\n\" + \"=\"*50)\n","print(\"COMPETITIVE ADVANTAGE WORD CLOUDS\")\n","print(\"=\"*50)\n","\n","fig, axes = plt.subplots(2, 2, figsize=(20, 12))\n","\n","# Positive aspects word clouds\n","for i, platform in enumerate(['Blinkit', 'Zepto']):\n","    positive_text = \" \".join(df[(df['platform']==platform) & (df['sentiment']==2)][review_col].dropna().astype(str))\n","    if positive_text.strip():\n","        wordcloud = WordCloud(width=600, height=300, background_color=\"white\",\n","                             colormap=\"Greens\").generate(positive_text)\n","        axes[0,i].imshow(wordcloud, interpolation=\"bilinear\")\n","        axes[0,i].set_title(f'{platform} - Positive Aspects\\n(Strengths)', fontweight='bold', size=14)\n","        axes[0,i].axis(\"off\")\n","\n","# Negative aspects word clouds\n","for i, platform in enumerate(['Blinkit', 'Zepto']):\n","    negative_text = \" \".join(df[(df['platform']==platform) & (df['sentiment']==0)][review_col].dropna().astype(str))\n","    if negative_text.strip():\n","        wordcloud = WordCloud(width=600, height=300, background_color=\"white\",\n","                             colormap=\"Reds\").generate(negative_text)\n","        axes[1,i].imshow(wordcloud, interpolation=\"bilinear\")\n","        axes[1,i].set_title(f'{platform} - Negative Aspects\\n(Improvement Areas)', fontweight='bold', size=14)\n","        axes[1,i].axis(\"off\")\n","\n","plt.tight_layout()\n","plt.show()\n","\n","# -------------------------\n","# 5. FINANCIAL & OPERATIONAL METRICS (FIXED)\n","# -------------------------\n","\n","print(\"\\n\" + \"=\"*50)\n","print(\"FINANCIAL & OPERATIONAL INSIGHTS\")\n","print(\"=\"*50)\n","\n","# 5.1 Customer Lifetime Value Proxy (FIXED VERSION)\n","def calculate_clv_proxy(sentiment_series):\n","    \"\"\"Calculate CLV proxy based on sentiment distribution - FIXED\"\"\"\n","    sentiment_counts = sentiment_series.value_counts()\n","\n","    # Ensure all sentiment categories are present\n","    for sentiment in ['Positive', 'Neutral', 'Negative']:\n","        if sentiment not in sentiment_counts:\n","            sentiment_counts[sentiment] = 0\n","\n","    # Weighted average where positive sentiment contributes more to CLV\n","    weights = {'Positive': 1.0, 'Neutral': 0.5, 'Negative': 0.1}\n","    total_reviews = sentiment_counts.sum()\n","\n","    if total_reviews > 0:\n","        clv_score = sum(sentiment_counts[sentiment] * weights[sentiment]\n","                       for sentiment in sentiment_counts.index) / total_reviews\n","        return clv_score * 100  # Scale for better interpretation\n","    else:\n","        return 0\n","\n","clv_insights = {}\n","for platform in ['Blinkit', 'Zepto']:\n","    platform_sentiments = df[df['platform'] == platform]['sentiment_label']\n","    clv_insights[platform] = calculate_clv_proxy(platform_sentiments)\n","\n","print(\"\\nCustomer Lifetime Value Proxy (Higher is Better):\")\n","for platform, score in clv_insights.items():\n","    print(f\"  {platform}: {score:.1f}\")\n","\n","# 5.2 Risk Assessment based on Negative Review Concentration\n","negative_ratio = {\n","    'Blinkit': len(blinkit_data[blinkit_data['sentiment'] == 0]) / len(blinkit_data) * 100 if len(blinkit_data) > 0 else 0,\n","    'Zepto': len(zepto_data[zepto_data['sentiment'] == 0]) / len(zepto_data) * 100 if len(zepto_data) > 0 else 0\n","}\n","\n","print(\"\\nCustomer Dissatisfaction Risk (% Negative Reviews):\")\n","for platform, ratio in negative_ratio.items():\n","    risk_level = \"High\" if ratio > 20 else \"Medium\" if ratio > 10 else \"Low\"\n","    print(f\"  {platform}: {ratio:.1f}% ({risk_level} Risk)\")\n","\n","# 5.3 Revenue Impact Estimation\n","print(\"\\nRevenue Impact Estimation:\")\n","for platform in ['Blinkit', 'Zepto']:\n","    platform_data = df[df['platform'] == platform]\n","    positive_reviews = len(platform_data[platform_data['sentiment'] == 2])\n","    total_reviews = len(platform_data)\n","\n","    if total_reviews > 0:\n","        satisfaction_rate = positive_reviews / total_reviews\n","        # Assuming higher satisfaction leads to better retention and revenue\n","        revenue_potential = satisfaction_rate * 100\n","        print(f\"  {platform}: Satisfaction Index: {revenue_potential:.1f}/100\")\n","\n","# -------------------------\n","# 6. STRATEGIC RECOMMENDATIONS\n","# -------------------------\n","\n","print(\"\\n\" + \"=\"*60)\n","print(\"STRATEGIC RECOMMENDATIONS\")\n","print(\"=\"*60)\n","\n","# Generate data-driven recommendations\n","blinkit_positive = len(blinkit_data[blinkit_data['sentiment'] == 2]) / len(blinkit_data) * 100 if len(blinkit_data) > 0 else 0\n","zepto_positive = len(zepto_data[zepto_data['sentiment'] == 2]) / len(zepto_data) * 100 if len(zepto_data) > 0 else 0\n","\n","blinkit_negative = len(blinkit_data[blinkit_data['sentiment'] == 0]) / len(blinkit_data) * 100 if len(blinkit_data) > 0 else 0\n","zepto_negative = len(zepto_data[zepto_data['sentiment'] == 0]) / len(zepto_data) * 100 if len(zepto_data) > 0 else 0\n","\n","print(\"\\nMARKETING RECOMMENDATIONS:\")\n","if blinkit_positive > zepto_positive:\n","    print(\"✓ Blinkit should leverage higher satisfaction in marketing campaigns\")\n","    print(\"✓ Zepto needs reputation management and quality improvement focus\")\n","else:\n","    print(\"✓ Zepto has customer satisfaction advantage for marketing\")\n","    print(\"✓ Blinkit should address quality concerns before scaling marketing\")\n","\n","print(\"\\nOPERATIONAL RECOMMENDATIONS:\")\n","if blinkit_negative > zepto_negative:\n","    print(\"✓ Bli
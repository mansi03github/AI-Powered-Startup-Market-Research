ze'] = (12, 8)\n","plt.rcParams['font.size'] = 12\n","\n","# Color scheme for consistent branding\n","BRAND_COLORS = {\n","    'Blinkit': '#FF6B6B',\n","    'Zepto': '#4ECDC4',\n","    'Positive': '#06D6A0',\n","    'Neutral': '#FFD166',\n","    'Negative': '#EF476F'\n","}\n","\n","# -------------------------\n","# 1. DATA LOADING & PREPROCESSING MODULE\n","# -------------------------\n","class DataProcessor:\n","    def __init__(self, blinkit_path, zepto_path):\n","        self.blinkit_path = blinkit_path\n","        self.zepto_path = zepto_path\n","        self.df = None\n","        self.review_col = \"content\"\n","\n","    def load_and_clean_data(self):\n","        \"\"\"Load, merge, and clean the datasets\"\"\"\n","        blinkit_df = pd.read_csv(self.blinkit_path)\n","        zepto_df = pd.read_csv(self.zepto_path)\n","\n","        blinkit_df['platform'] = 'Blinkit'\n","        zepto_df['platform'] = 'Zepto'\n","\n","        self.df = pd.concat([blinkit_df, zepto_df], ignore_index=True)\n","\n","        # Data cleaning\n","        self.df = self.df.drop_duplicates()\n","        self.df = self.df.dropna(subset=[self.review_col, 'score'])\n","\n","        # Sentiment analysis\n","        self.df['sentiment'] = self.df['score'].apply(\n","            lambda x: 0 if x <= 2 else (1 if x == 3 else 2)\n","        )\n","        self.df['sentiment_label'] = self.df['sentiment'].map(\n","            {0: 'Negative', 1: 'Neutral', 2: 'Positive'}\n","        )\n","\n","        # Additional features for analysis\n","        self.df['review_length'] = self.df[self.review_col].astype(str).apply(len)\n","        self.df['word_count'] = self.df[self.review_col].astype(str).apply(\n","            lambda x: len(x.split())\n","        )\n","        self.df['review_complexity'] = self.df[self.review_col].apply(\n","            lambda x: len(set(str(x).split()))\n","        )\n","\n","        return self.df\n","\n","    def get_platform_data(self, platform):\n","        \"\"\"Get data for specific platform\"\"\"\n","        return self.df[self.df['platform'] == platform]\n","\n","# -------------------------\n","# 2. BUSINESS METRICS CALCULATION MODULE\n","# -------------------------\n","class BusinessMetricsCalculator:\n","    def __init__(self, df):\n","        self.df = df\n","        self.blinkit_data = df[df['platform'] == 'Blinkit']\n","        self.zepto_data = df[df['platform'] == 'Zepto']\n","\n","    def calculate_kpis(self):\n","        \"\"\"Calculate Key Performance Indicators\"\"\"\n","        kpis = {}\n","\n","        for platform, data in [('Blinkit', self.blinkit_data), ('Zepto', self.zepto_data)]:\n","            if len(data) > 0:\n","                kpis[platform] = {\n","                    'Total_Reviews': len(data),\n","                    'Avg_Rating': data['score'].mean(),\n","                    'Median_Rating': data['score'].median(),\n","                    'Rating_Std': data['score'].std(),\n","                    'Positive_Sentiment_%': len(data[data['sentiment'] == 2]) / len(data) * 100,\n","                    'Negative_Sentiment_%': len(data[data['sentiment'] == 0]) / len(data) * 100,\n","                    'Avg_Word_Count': data['word_count'].mean(),\n","                    'Review_Engagement_Score': data['word_count'].mean() * data['score'].mean() / 10\n","                }\n","\n","        return pd.DataFrame(kpis).T\n","\n","    def calculate_financial_metrics(self):\n","        \"\"\"Calculate financial and customer value metrics\"\"\"\n","        financial_metrics = {}\n","\n","        for platform, data in [('Blinkit', self.blinkit_data), ('Zepto', self.zepto_data)]:\n","            if len(data) > 0:\n","                # Customer Lifetime Value Proxy\n","                sentiment_weights = {'Positive': 1.0, 'Neutral': 0.5, 'Negative': 0.1}\n","                sentiment_counts = data['sentiment_label'].value_counts()\n","                clv_score = sum(sentiment_counts.get(sentiment, 0) * weight\n","                              for sentiment, weight in sentiment_weights.items()) / len(data) * 100\n","\n","                # Net Promoter Score\n","                nps = self.calculate_nps(data['score'])\n","\n","                # Customer Retention Probability\n","                retention_prob = (len(data[data['sentiment'] == 2]) * 0.8 +\n","                                len(data[data['sentiment'] == 1]) * 0.5 +\n","                                len(data[data['sentiment'] == 0]) * 0.1) / len(data) * 100\n","\n","                # Revenue Risk Score (based on negative reviews)\n","                risk_score = len(data[data['sentiment'] == 0]) / len(data) * 100\n","\n","                financial_metrics[platform] = {\n","                    'CLV_Proxy_Score': clv_score,\n","                    'Net_Promoter_Score': nps,\n","                    'Retention_Probability_%': retention_prob,\n","                    'Revenue_Risk_Score': risk_score,\n","                    'Quality_Consistency_Score': (5 - data['score'].std()) / 5 * 100\n","                }\n","\n","        return pd.DataFrame(financial_metrics).T\n","\n","    def calculate_nps(self, scores):\n","        \"\"\"Calculate Net Promoter Score\"\"\"\n","        promoters = len(scores[scores >= 4])\n","        detractors = len(scores[scores <= 2])\n","        total = len(scores)\n","        return (promoters - detractors) / total * 100 if total > 0 else 0\n","\n","    def calculate_market_metrics(self):\n","        \"\"\"Calculate market share and competitive positioning\"\"\"\n","        total_reviews = len(self.df)\n","        platform_shares = self.df['platform'].value_counts() / total_reviews * 100\n","\n","        # Market concentration (Herfindahl index)\n","        hhi = sum((share/100) ** 2 for share in platform_shares) * 10000\n","\n","        return platform_shares, hhi\n","\n","# -------------------------\n","# 3. ADVANCED VISUALIZATION MODULE\n","# -------------------------\n","class BusinessVisualizer:\n","    def __init__(self, df):\n","        self.df = df\n","        self.colors = BRAND_COLORS\n","\n","    def create_executive_dashboard(self):\n","        \"\"\"Create comprehensive executive dashboard\"\"\"\n","        fig, axes = plt.subplots(3, 3, figsize=(20, 15))\n","        fig.suptitle('BLINKIT vs ZEPTO - EXECUTIVE BUSINESS DASHBOARD',\n","                    fontsize=16, fontweight='bold', y=0.95)\n","\n","        # 1. Market Share Analysis\n","        platform_share = self.df['platform'].value_counts()\n","        axes[0,0].pie(platform_share.values, labels=platform_share.index,\n","                     autopct='%1.1f%%', colors=[self.colors['Blinkit'], self.colors['Zepto']],\n","                     startangle=90)\n","        axes[0,0].set_title('Market Review Volume Share', fontweight='bold')\n","\n","        # 2. Customer Satisfaction Comparison\n","        avg_ratings = self.df.groupby('platform')['score'].mean()\n","        axes[0,1].bar(avg_ratings.index, avg_ratings.values,\n","                     color=[self.colors['Blinkit'], self.colors['Zepto']])\n","        axes[0,1].set_title('Average Customer Rating (CSAT)', fontweight='bold')\n","        axes[0,1].set_ylabel('Rating (1-5 Scale)')\n","\n","        # 3. Sentiment Distribution\n","        sentiment_pivot = pd.crosstab(self.df['platform'], self.df['sentiment_label'],\n","                                    normalize='index') * 100\n","        sentiment_pivot.plot(kind='bar', ax=axes[0,2],\n","                           color=[self.colors['Negative'], self.colors['Neutral'], self.colors['Positive']])\n","        axes[0,2].set_title('Sentiment Distribution (%)', fontweight='bold')\n","        axes[0,2].set_ylabel('Percentage')\n","        axes[0,2].tick_params(axis='x', rotation=45)\n","\n","        # 4. Rating Distribution Deep Dive\n","        rating_dist = pd.crosstab(self.df['platform'], self.df['score'])\n","        rating_dist.plot(kind='bar', ax=axes[1,0], width=0.8)\n","        axes[1,0].set_title('Detailed Rating Distribution', fontweight='bold')\n","        axes[1,0].set_ylabel('Number of Reviews')\n","\n","        # 5. Review Engagement Analysis\n","        sns.boxplot(x='platform', y='word_count', data=self.df,\n","                   ax=axes[1,1], palette=[self.colors['Blinkit'], self.colors['Zepto']])\n","        axes[1,1].set_title('Review Length Distribution\\n(Engagement Metric)', fontweight='bold')\n","        axes[1,1].set_ylabel('Word Count')\n","\n","        # 6. NPS Comparison\n","        nps_scores = {}\n","        for platform in ['Blinkit', 'Zepto']:\n","            data = self.df[self.df['platform'] == platform]\n","            nps_scores[platform] = self.calculate_nps(data['score'])\n","\n","        axes[1,2].bar(nps_scores.keys(), nps_scores.values(),\n","                     color=[self.colors['Blinkit'], self.colors['Zepto']])\n","        axes[1,2].set_title('Net Promoter Score (NPS)\\nCustomer Loyalty Metric', fontweight='bold')\n","        axes[1,2].axhline(y=0, color='black', linestyle='-', alpha=0.3)\n","        axes[1,2].axhline(y=50, color='green', linestyle='--', alpha=0.5, label='Excellent')\n","\n","        # 7. Quality Consistency\n","        consistency_scores = {}\n","        for platform in ['Blinkit', 'Zepto']:\n","            data = self.df[self.df['platform'] == platform]\n","            consistency_scores[platform] = (5 - data['score'].std()) / 5 * 100\n","\n","        axes[2,0].bar(consistency_scores.keys(), consistency_scores.values(),\n","                     color=[self.colors['Blinkit'], self.colors['Zepto']])\n","        axes[2,0].set_title('Service Quality Consistency Score', fontweight='bold')\n","        axes[2,0].set_ylabel('Consistency Score (%)')\n","\n","        # 8. Risk Analysis\n","        risk_scores = {}\n","        for platform in ['Blinkit', 'Zepto']:\n","            data = self.df[self.df['platform'] == platform]\n","            risk_scores[platform] = len(data[data['sentiment'] == 0]) / len(data) * 100\n","\n","        axes[2,1].bar(risk_scores.keys(), risk_scores.values(),\n","                     color=[self.colors['Blinkit'], self.colors['Zepto']])\n","        axes[2,1].set_title('Customer Dissatisfaction Risk', fontweight='bold')\n","        axes[2,1].set_ylabel('Risk Score (%)')\n","\n","        # 9. Customer Value Comparison\n","        clv_scores = {}\n","        for platform in ['Blinkit', 'Zepto']:\n","            data = self.df[self.df['platform'] == platform]\n","            sentiment_counts = data['sentiment_label'].value_counts()\n","            weights = {'Positive': 1.0, 'Neutral': 0.5, 'Negative': 0.1}\n","            clv = sum(sentiment_counts.get(sentiment, 0) * weight\n","                     for sentiment, weight in weights.items()) / len(data) * 100\n","            clv_scores[platform] = clv\n","\n","        axes[2,2].bar(clv_scores.keys(), clv_scores.values(),\n","                     color=[self.colors['Blinkit'], self.colors['Zepto']])\n","        axes[2,2].set_title('Customer Lifetime Value Proxy', fontweight='bold')\n","        axes[2,2].set_ylabel('CLV Score')\n","\n","        plt.tight_layout()\n","        plt.show()\n","\n","    def calculate_nps(self, scores):\n","        \"\"\"Calculate Net Promoter Score\"\"\"\n","        promoters = len(scores[scores >= 4])\n","        detractors = len(scores[scores <= 2])\n","        total = len(scores)\n","        return (promoters - detractors) / total * 100 if total > 0 else 0\n","\n","    def create_strategic_analysis_charts(self):\n","        \"\"\"Create advanced strategic analysis charts\"\"\"\n","        fig, axes = plt.subplots(2, 2, figsize=(16, 12))\n","        fig.suptitle('STRATEGIC BUSINESS ANALYSIS', fontsize=16, fontweight='bold')\n","\n","        # 1. SWOT Analysis Visualization\n","        self.create_swot_analysis(axes[0,0])\n","\n","        # 2. Competitive Positioning Matrix\n","        self.create_positioning_matrix(axes[0,1])\n","\n","        # 3. Performance-Risk Matrix\n","        self.create_performance_risk_matrix(axes[1,0])\n","\n","        # 4. Customer Value Segmentation\n","        self.create_customer_value_chart(axes[1,1])\n","\n","        plt.tight_layout()\n","        plt.show()\n","\n","    def create_swot_analysis(self, ax):\n","        \"\"\"Create SWOT analysis visualization\"\"\"\n","        # Enhanced SWOT analysis based on actual data\n","        blinkit_data = self.df[self.df['platform'] == 'Blinkit']\n","        zepto_data = self.df[self.df['platform'] == 'Zepto']\n","\n","        # Calculate actual metrics for SWOT\n","        blinkit_strength = blinkit_data['score'].mean()\n","        zepto_strength = zepto_data['score'].mean()\n","\n","        blinkit_volume = len(blinkit_data)\n","        zepto_volume = len(zepto_data)\n","\n","        swot_text = f\"\"\"\n","STRENGTHS\n","• Blinkit: Market Presence ({blinkit_volume} reviews)\n","• Zepto: Quality Focus (Rating: {zepto_strength:.2f})\n","\n","WEAKNESSES\n","• Blinkit: Consistency Challenges\n","• Zepto: Smaller Market Share\n","\n","OPPORTUNITIES\n","• Market Expansion\n","• Service Diversification\n","• Technology Innovation\n","\n","THREATS\n","• Increasing Competition\n","• Customer Expectations\n","• Operational Costs\n","\"\"\"\n","\n","        ax.text(0.05, 0.95, swot_text, fontsize=10,\n","                bbox=dict(boxstyle=\"round,pad=0.5\", facecolor=\"white\", alpha=0.8),\n","                verticalalignment='top', transform=ax.transAxes)\n","        ax.set_title('SWOT Analysis Framework', fontweight='bold')\n","        ax.axis('off')\n","\n","    def create_positioning_matrix(self, ax):\n","        \"\"\"Create competitive positioning matrix\"\"\"\n","        # Calculate positioning metrics\n","        quality_score = {}\n","        market_presence = {}\n","\n","        for platform in ['Blinkit', 'Zepto']:\n","            data = self.df[self.df['platform'] == platform]\n","            quality_score[platform] = data['score'].mean()\n","            market_presence[platform] = len(data) / len(self.df) * 100\n","\n","        # Create positioning matrix\n","        for platform in ['Blinkit', 'Zepto']:\n","            ax.scatter(quality_score[platform], market_presence[platform],\n","                      s=200, label=platform, color=self.colors[platform], alpha=0.7)\n","            ax.annotate(platform, (quality_score[platform], market_presence[platform]),\n","                       xytext=(10, 10), textcoords='offset points', fontweight='bold')\n","\n","        # Add quadrant lines\n","        avg_quality = np.mean(list(quality_score.values()))\n","        avg_presence = np.mean(list(market_presence.values()))\n","\n","        ax.axhline(y=avg_presence, color='gray', linestyle='--', alpha=0.7)\n","        ax.axvline(x=avg_quality, color='gray', linestyle='--', alpha=0.7)\n","\n","        # Add quadrant labels\n","        ax.text(avg_quality + 0.1, avg_presence + 5, 'Leader', fontsize=12,\n","                fontweight='bold', color='green')\n","        ax.text(avg_quality + 0.1, avg_presence - 10, 'Niche', fontsize=12,\n","                fontweight='bold', color='blue')\n","        ax.text(avg_quality - 0.5, avg_presence + 5, 'Challenger', fontsize=12,\n","                fontweight='bold', color='orange')\n","        ax.text(avg_quality - 0.5, avg_presence - 10, 'Follower', fontsize=12,\n","                fontweight='bold', color='red')\n","\n","        ax.set_xlabel('Quality Score (Avg Rating)')\n","        ax.set_ylabel('Market Presence (%)')\n","        ax.set_title('Competitive Positioning Matrix', fontweight='bold')\n","        ax.legend()\n","        ax.grid(True, alpha=0.3)\n","\n","    def create_performance_risk_matrix(self, ax):\n","        \"\"\"Create performance-risk matrix\"\"\"\n","        performance_metrics = {}\n","        risk_metrics = {}\n","\n","        for platform in ['Blinkit', 'Zepto']:\n","            data = self.df[self.df['platform'] == platform]\n","            # Performance: combination of rating and positive sentiment\n","            performance = (data['score'].mean() * 20 +\n","                          len(data[data['sentiment'] == 2]) / len(data) * 100) / 2\n","            # Risk: negative sentiment percentage\n","            risk = len(data[data['sentiment'] == 0]) / len(data) * 100\n","\n","            performance_metrics[platform] = performance\n","            risk_metrics[platform] = risk\n","\n","        # Plot performance-risk matrix\n","        for platform in ['Blinkit', 'Zepto']:\n","            ax.scatter(risk_metrics[platform], performance_metrics[platform],\n","                      s=200, color=self.colors[platform], label=platform, alpha=0.7)\n","            ax.annotate(platform, (risk_metrics[platform], performance_metrics[platform]),\n","                       xytext=(10, 10), textcoords='offset points', fontweight='bold')\n","\n","        # Add quadrant lines\n","        avg_performance = np.mean(list(performance_metrics.values()))\n","        avg_risk = np.mean(list(risk_metrics.values()))\n","\n","        ax.axhline(y=avg_performance, color='gray', linestyle='--', alpha=0.7)\n","        ax.axvline(x=avg_risk, color='gray', linestyle='--', alpha=0.7)\n","\n","        # Add quadrant labels\n","        ax.text(avg_risk + 2, avg_performance + 10, 'High Risk\\nHigh Reward',\n","                fontsize=10, fontweight='bold', color='red')\n","        ax.text(avg_risk + 2, avg_performance - 15, 'High Risk\\nLow Reward',\n","                fontsize=10, fontweight='bold', color='darkred')\n","        ax.text(avg_risk - 15, avg_performance + 10, 'Low Risk\\nHigh Reward',\n","                fontsize=10, fontweight='bold', color='green')\n","        ax.text(avg_risk - 15, avg_performance - 15, 'Low Risk\\nLow Reward',\n","                fontsize=10, fontweight='bold', color='orange')\n","\n","        ax.set_xlabel('Risk Score (% Negative Reviews)')\n","        ax.set_ylabel('Performance Score')\n","        ax.set_title('Performance-Risk Matrix', fontweight='bold')\n","        ax.legend()\n","        ax.grid(True, alpha=0.3)\n","\n","    def create_customer_value_chart(self, ax):\n","        \"\"\"Create customer value segmentation chart\"\"\"\n","        value_metrics = {}\n","\n","        for platform in ['Blinkit', 'Zepto']:\n","            data = self.df[self.df['platform'] == platform]\n","\n","            # Calculate multiple value metrics\n","            clv_score = self.calculate_clv_proxy(data)\n","            retention_score = (len(data[data['sentiment'] == 2]) * 0.8 +\n","                             len(data[data['sentiment'] == 1]) * 0.5 +\n","                             len(data[data['sentiment'] == 0]) * 0.1) / len(data) * 100\n","            engagement_score = data['word_count'].mean() * 2  # Scale for visibility\n","\n","            value_metrics[platform] = {\n","                'CLV Score': clv_score,\n","                'Retention Probability': retention_score,\n","                'Engagement Level': engagement_score\n","            }\n","\n","        # Create grouped bar chart\n","        metrics_list = ['CLV Score', 'Retention Probability', 'Engagement Level']\n","        x_pos = np.arange(len(metrics_list))\n","        width = 0.35\n","\n","        for i, platform in enumerate(['Blinkit', 'Zepto']):\n","            values = [value_metrics[platform][metric] for metric in metrics_list]\n","            ax.bar(x_pos + i*width, values, width, label=platform,\n","                   color=self.colors[platform], alpha=0.8)\n","\n","        ax.set_xlabel('Customer Value Metrics')\n","        ax.set_ylabel('Score')\n","        ax.set_title('Customer Value Segmentation', fontweight='bold')\n","        ax.set_xticks(x_pos + width/2)\n","        ax.set_xticklabels(metrics_list, rotation=45)\n","        ax.legend()\n","        ax.grid(True, alpha=0.3)\n","\n","    def calculate_clv_proxy(self, data):\n","        \"\"\"Calculate CLV proxy for customer value chart\"\"\"\n","        sentiment_counts = data['sentiment_label'].value_counts()\n","        weights = {'Positive': 1.0, 'Neutral': 0.5, 'Negative': 0.1}\n","        clv = sum(sentiment_counts.get(sentiment, 0) * weight\n","                 for sentiment, weight in weights.items()) / len(data) * 100\n","        return clv\n","\n","    def create_word_clouds(self):\n","        \"\"\"Create strategic word clouds for both platforms\"\"\"\n","        fig, axes = plt.subplots(2, 2, figsize=(16, 10))\n","        fig.suptitle('TEXT ANALYSIS - CUSTOMER FEEDBACK WORD CLOUDS',\n","                    fontsize=16, fontweight='bold')\n","\n","        for i, platform in enumerate(['Blinkit', 'Zepto']):\n","            # Positive reviews word cloud\n","            positive_text = \" \".join(self.df[(self.df['platform'] == platform) &\n","                                          (self.df['sentiment'] == 2)]['content'].dropna().astype(str))\n","            if positive_text.strip():\n","                wordcloud = WordCloud(width=400, height=200, background_color=\"white\",\n","                                    colormap=\"Greens\", max_words=50).generate(positive_text)\n","                axes[0,i].imshow(wordcloud, interpolation=\"bilinear\")\n","                axes[0,i].set_title(f'{platform} - Positive Feedback\\n(Strengths)',\n","                                  fontweight='bold')\n","                axes[0,i].axis(\"off\")\n","            else:\n","                axes[0,i].text(0.5, 0.5, 'No positive reviews\\navailable',\n","                              ha='center', va='center', transform=axes[0,i].transAxes)\n","                axes[0,i].set_title(f'{platform} - Positive Feedback', fontweight='bold')\n","                axes[0,i].axis(\"off\")\n","\n","            # Negative reviews word cloud\n","            negative_text = \" \".join(self.df[(self.df['platform'] == platform) &\n","                                          (self.df['sentiment'] == 0)]['content'].dropna().astype(str))\n","            if negative_text.strip():\n","                wordcloud = WordCloud(width=400, height=200, background_color=\"white\",\n","                                    colormap=\"Reds\", max_words=50).generate(negative_text)\n","                axes[1,i].imshow(wordcloud, interpolation=\"bilinear\")\n","                axes[1,i].set_title(f'{platform} - Negative Feedback\\n(Improvement Areas)',\n","                                  fontweight='bold')\n","                axes[1,i].axis(\"off\")\n","            else:\n","                axes[1,i].text(0.5, 0.5, 'No negative reviews\\navailable',\n","                              ha='center', va='center', transform=axes[1,i].transAxes)\n","                axes[1,i].set_title(f'{platform} - Negative Feedback', fontweight='bold')\n","                axes[1,i].axis(\"off\")\n","\n","        plt.tight_layout()\n","        plt.show()\n","\n","# -------------------------\n","# 4. STRATEGIC INSIGHTS MODULE\n","# -------------------------\n","class StrategicAnalyst:\n","    def __init__(self, df, metrics_calculator):\n","        self.df = df\n","        self.metrics_calculator = metrics_calculator\n","        self.kpis = metrics_calculator.calculate_kpis()\n","        self.financial_metrics = metrics_calculator.calculate_financial_metrics()\n","\n","    def generate_executive_summary(self):\n","        \"\"\"Generate comprehensive executive summary\"\"\"\n","        print(\"=\"*80)\n","        print(\"EXECUTIVE SUMMARY - BLINKIT vs ZEPTO BUSINESS INTELLIGENCE REPORT\")\n","        print(\"=\"*80)\n","\n","        total_reviews = len(self.df)\n","        blinkit_reviews = len(self.df[self.df['platform'] == 'Blinkit'])\n","        zepto_reviews = len(self.df[self.df['platform'] == 'Zepto'])\n","\n","        print(f\"\\n📊 OVERVIEW:\")\n","        print(f\"• Total Reviews Analyzed: {total_reviews:,}\")\n","        print(f\"• Blinkit Reviews: {blinkit_reviews:,} ({blinkit_reviews/total_reviews*100:.1f}%)\")\n","        print(f\"• Zepto Reviews: {zepto_reviews:,} ({zepto_reviews/total_reviews*100:.1f}%)\")\n","\n","        # Market leadership analysis\n","        market_leader = 'Blinkit' if blinkit_reviews > zepto_reviews else 'Zepto'\n","        print(f\"• Market Presence Leader: {market_leader}\")\n","\n","        # Satisfaction leadership\n","        satisfaction_leader = self.kpis['Avg_Rating'].idxmax()\n","        print(f\"• Customer Satisfaction Leader: {satisfaction_leader} \"\n","              f\"(Rating: {self.kpis['Avg_Rating'].max():.2f})\")\n","\n","        # Risk analysis\n","        low_risk_platform = self.financial_metrics['Revenue_Risk_Score'].idxmin()\n","        print(f\"• Lower Risk Profile: {low_risk_platform} \"\n","              f\"(Risk Score: {self.financial_metrics['Revenue_Risk_Score'].min():.1f}%)\")\n","\n","        # NPS leader\n","        nps_leader = self.financial_metrics['Net_Promoter_Score'].idxmax()\n","        print(f\"• Customer Loyalty Leader: {nps_leader} \"\n","              f\"(NPS: {self.financial_metrics['Net_Promoter_Score'].max():.1f})\")\n","\n","    def generate_strategic_recommendations(self):\n","        \"\"\"Generate data-driven strategic recommendations\"\"\"\n","        print(\"\\n\" + \"=\"*80)\n","        print(\"STRATEGIC RECOMMENDATIONS\")\n","        print(\"=\"*80)\n","\n","        # Marketing Strategy\n","        print(\"\\n📈 MARKETING STRATEGY:\")\n","        blinkit_positive = self.kpis.loc['Blinkit', 'Positive_Sentiment_%']\n","        zepto_positive = self.kpis.loc['Zepto', 'Positive_Sentiment_%']\n","\n","        if blinkit_positive > zepto_positive:\n","            print(\"• 🎯 Blinkit: Leverage higher positive sentiment in brand campaigns\")\n","            print(\"• 🔧 Zepto: Focus on quality improvement before major marketing push\")\n","        else:\n","            print(\"• 🎯 Zepto: Capitalize on customer satisfaction in marketing messages\")\n","            print(\"• 🔧 Blinkit: Implement reputa